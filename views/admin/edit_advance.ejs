<%- include('navbar') %>

<style>

body{
background:#f1f5fb;
font-family:'Segoe UI',sans-serif;
}

.page-header{
background:linear-gradient(135deg,#007bff,#00c6ff);
color:white;
padding:20px 25px;
border-radius:10px;
margin-bottom:25px;
}

.form-card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
max-width:700px;
margin:auto;
}

.form-control{
height:45px;
border-radius:8px;
}

.update-btn{
background:#007bff;
border:none;
padding:10px 40px;
border-radius:8px;
color:white;
font-weight:600;
}

.update-btn:hover{
background:#0056d2;
}

</style>

<div class="container py-4">

<div class="page-header">
<h4 class="mb-0">Edit Advance Payment</h4>
</div>

<div class="form-card">

<form action="/update_advance/<%= advance.advance_id %>" method="POST">

<div class="row">

<div class="col-md-12 mb-3">

<label>Select Employee</label>

<select class="form-control" name="employee_id">

<% employees.forEach(emp=>{ %>

<option value="<%= emp.employee_id %>"
<%= emp.employee_id == advance.employee_id ? 'selected':'' %>>

<%= emp.employee_name %>

</option>

<% }) %>

</select>

</div>


<div class="col-md-6 mb-3">

<label>Advance Date</label>

<input type="date"
class="form-control"
name="advance_date"
value="<%= advance.advance_date.toISOString().split('T')[0] %>">

</div>


<div class="col-md-6 mb-3">

<label>Amount</label>

<input type="number"
class="form-control"
name="amount"
value="<%= advance.advance_amount %>">

</div>


<div class="col-md-12 mb-3">

<label>Remark</label>

<textarea class="form-control"
name="remark"
rows="3"><%= advance.advance_note %></textarea>

</div>


<div class="col-md-12 text-end">

<button class="update-btn">
Update Advance
</button>

</div>

</div>

</form>

</div>

</div>

<%- include('footer') %>