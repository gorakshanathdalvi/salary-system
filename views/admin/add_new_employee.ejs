<%- include('navbar') %>

<style>

body{
    background:#eef2f7;
    font-family:'Segoe UI',sans-serif;
}

/* Header */
.page-header{
    background:linear-gradient(135deg,#007bff,#00c6ff);
    padding:20px 30px;
    color:white;
    border-radius:10px;
    margin-bottom:25px;
}

/* Card */
.form-card{
    background:white;
    border-radius:12px;
    padding:35px;
    box-shadow:0 15px 35px rgba(0,0,0,0.08);
}

/* Section Title */
.section-title{
    font-weight:600;
    font-size:18px;
    margin-bottom:20px;
    border-left:4px solid #007bff;
    padding-left:10px;
}

/* Inputs */
.form-control, .form-select{
    height:46px;
    border-radius:8px;
    border:1px solid #ddd;
}

.form-control:focus{
    border-color:#007bff;
    box-shadow:none;
}

/* Button */
.save-btn{
    background:linear-gradient(135deg,#007bff,#0056d2);
    border:none;
    height:45px;
    color:white;
    border-radius:8px;
    font-weight:600;
    padding:0 40px;
}

.save-btn:hover{
    opacity:0.9;
}

/* Responsive spacing */
@media(max-width:768px){
    .form-card{
        padding:20px;
    }
}

</style>

<div class="container-fluid admin-page-container py-4">

<div class="page-header">
<h4 class="mb-0">Add New Employee</h4>
<a href="/employee_list" class="btn btn-lg btn-outline-light ">View Employee List</a>
</div>

<div class="form-card">
<% if(typeof success_msg !== 'undefined' && success_msg){ %>
<div class=" bg-success text-white p-alert alert-success"><%= success_msg %></div>
<br><br>
<% } %>

<% if(typeof error_msg !== 'undefined' && error_msg){ %>
<div class="alert alert-danger"><%= error_msg %></div>
<% } %>
<form action="/add_employee" method="POST">

<!-- Employee Info -->

<div class="section-title">Employee Information</div>

<div class="row">

<div class="col-md-6 mb-3">
<label>Employee Name</label>
<input type="text" class="form-control" name="employee_name" required>
</div>

<div class="col-md-6 mb-3">
<label>Mobile Number</label>
<input type="text" class="form-control" name="employee_mobile">
</div>

<div class="col-md-6 mb-3">
<label>Joining Date</label>
<input type="date" class="form-control" name="joining_date">
</div>

<div class="col-md-6 mb-3">
<label>Salary Type</label>
<select class="form-select" name="salary_type" id="salaryType" required>
<option value="">Select Salary Type</option>
<option value="monthly">Monthly</option>
<option value="daily">Daily Wage</option>
</select>
</div>

<div class="col-md-12 mb-3">
<label>Address</label>
<textarea class="form-control" name="employee_address" rows="3"></textarea>
</div>

</div>

<hr>

<!-- Salary Section -->

<div class="section-title">Salary Details</div>

<div class="row">

<div class="col-md-4 mb-3" id="monthlySalaryBox" style="display:none;">
<label>Monthly Salary</label>
<input type="number" class="form-control" name="monthly_salary">
</div>

<div class="col-md-4 mb-3" id="dailyWageBox" style="display:none;">
<label>Daily Wage</label>
<input type="number" class="form-control" name="daily_wage">
</div>

<div class="col-md-4 mb-3">
<label>Overtime Rate</label>
<input type="number" class="form-control" name="overtime_rate">
</div>

</div>

<hr>

<div class="text-end">
<button type="submit" class="btn save-btn">
Save Employee
</button>
</div>

</form>

</div>
</div>

<script>

const salaryType = document.getElementById("salaryType");
const monthlyBox = document.getElementById("monthlySalaryBox");
const dailyBox = document.getElementById("dailyWageBox");

salaryType.addEventListener("change", function(){

    if(this.value === "monthly"){
        monthlyBox.style.display = "block";
        dailyBox.style.display = "none";
    }
    else if(this.value === "daily"){
        monthlyBox.style.display = "none";
        dailyBox.style.display = "block";
    }
    else{
        monthlyBox.style.display = "none";
        dailyBox.style.display = "none";
    }

});

</script>

<%- include('footer') %>    
