<%- include('navbar') %>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
background:#f1f5fb;
font-family:'Segoe UI',sans-serif;
}

.page-header{
background:linear-gradient(135deg,#007bff,#00c6ff);
color:white;
padding:20px 25px;
border-radius:10px;
margin-bottom:25px;
}

.filter-card{
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
margin-bottom:20px;
}

.table-card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
}

.table thead{
background:#007bff;
color:white;
}

</style>


<div class="container-fluid admin-page-container py-4">

<div class="page-header d-flex justify-content-between">

<h4 class="mb-0">Salary List</h4>

<a href="/salary_generate" class="btn btn-sm btn-outline-light">
Generate Salary
</a>

</div>


<!-- FILTER -->

<div class="filter-card">

<form method="GET" action="/salary_list">

<div class="row">

<div class="col-md-4">

<label>Employee</label>

<select class="form-control" name="employee_id">

<option value="">All Employees</option>

<% employees.forEach(emp=>{ %>

<option value="<%= emp.employee_id %>"
<%= employee_id == emp.employee_id ? 'selected':'' %>>

<%= emp.employee_name %>

</option>

<% }) %>

</select>

</div>


<div class="col-md-4">

<label>Salary Month</label>

<input type="month" class="form-control" name="salary_month" value="<%= salary_month %>">

</div>


<div class="col-md-4 d-flex align-items-end">

<button class="btn btn-primary w-50 me-2">
<i class="fa fa-search"></i> Filter
</button>

<a href="/salary_list" class="btn btn-secondary w-50">
<i class="fa fa-rotate-left"></i> Reset
</a>

</div>

</div>

</form>

</div>


<!-- TABLE -->

<div class="table-card">

<table id="salaryTable" class="table table-bordered table-hover">

<thead>

<tr>

<th>#</th>
<th>Employee</th>
<th>Period</th>
<th>Duty Hours</th>
<th>OT Hours</th>
<th>Duty Salary</th>
<th>OT Salary</th>
<th>Advance</th>
<th>Net Salary</th>
<th>Slip</th>

</tr>

</thead>

<tbody>

<% salary.forEach((row,index)=>{ %>

<tr>

<td><%= index+1 %></td>

<td><%= row.employee_name %></td>

<td>

<%= new Date(row.from_date).toLocaleDateString('en-GB') %>
-
<%= new Date(row.to_date).toLocaleDateString('en-GB') %>

</td>

<td><%= row.total_duty_hours %></td>

<td><%= row.total_ot_hours %></td>

<td>₹ <%= row.duty_salary %></td>

<td>₹ <%= row.ot_salary %></td>

<td class="text-danger">₹ <%= row.advance_deduction %></td>

<td class="text-success fw-bold">
₹ <%= row.net_salary %>
</td>

<td>

<a href="/salary_slip/<%= row.salary_id %>" 
class="btn btn-sm btn-primary">

<i class="fa fa-file"></i>

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>


<script src="https://code.jquery.com/jquery-3.7.1.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>

<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

<script>

$(document).ready(function(){

$('#salaryTable').DataTable({

dom:'Bfrtip',

buttons:[
{
extend:'excel',
className:'btn btn-success',
text:'Excel'
},
{
extend:'pdf',
className:'btn btn-danger',
text:'PDF'
}
]

});

});

</script>

<%- include('footer') %>
