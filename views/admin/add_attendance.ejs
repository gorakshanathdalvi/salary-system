<%- include('navbar') %>
<style>

body{
background:#f1f5fb;
font-family:'Segoe UI',sans-serif;
overflow-x:hidden;
}

.page-header{
background:linear-gradient(135deg,#007bff,#00c6ff);
color:white;
padding:20px 25px;
border-radius:10px;
margin-bottom:25px;
}

.form-card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
overflow-x:auto;
}

.table-scroll{
width:100%;
overflow-x:auto;
-webkit-overflow-scrolling:touch;
}

.attendance-table{
min-width:1700px;
width:max-content;
}

.table thead{
background:#007bff;
color:white;
white-space:nowrap;
}

.table td,
.table th{
vertical-align:middle;
white-space:nowrap;
}

.form-control{
height:40px;
border-radius:6px;
}

.save-btn{
background:#007bff;
border:none;
padding:10px 30px;
border-radius:8px;
color:white;
font-weight:600;
}

.save-btn:hover{
background:#0056d2;
}

.break-time{
display:none !important;
min-width:210px;
}

.time-12-picker{
display:flex;
gap:6px;
min-width:210px;
}

.time-12-picker .form-control{
min-width:62px;
}

@media(max-width:768px){

.form-card{
padding:15px;
}

.attendance-table{
min-width:1700px;
}

}

</style>
<div class="container py-4">

<div class="page-header">
<h4 class="mb-0">Add Attendance</h4>
<a href="/attendance_list" class="btn btn-sm btn-outline-light">View Attendance List</a>
</div>

<div class="form-card">

<form action="/save_attendance" method="POST">

<div class="row mb-4">

<div class="col-md-4">
<label>Select Date</label>
<input type="date" class="form-control" name="attendance_date" required>
</div>

</div>

<div class="table-scroll">

<table class="table table-bordered table-hover attendance-table">

<thead>
<tr>
<th>#</th>
<th>Employee</th>
<th>Status</th>
<th>In Time</th>
<th>Take Break</th>
<th>Break Start</th>
<th>Resume Time</th>
<th>Out Time</th>
</tr>
</thead>

<tbody>

<% employees.forEach((emp,index)=>{ %>

<tr>

<td><%= index+1 %></td>

<td>
<input type="hidden" name="employee_id[]" value="<%= emp.employee_id %>">
<strong><%= emp.employee_name %></strong>
</td>

<td>
<select class="form-control" name="status[]">
<option value="P">Present</option>
<option value="A">Absent</option>
<option value="H">Half Day</option>
</select>
</td>

<td>
<input type="hidden" name="in_time[]" class="time-value">
<div class="time-12-picker">
<select class="form-control time-hour">
<option value="">HH</option>
<% for(let h=1; h<=12; h++){ %>
<option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-minute">
<option value="">MM</option>
<% for(let m=0; m<60; m++){ %>
<option value="<%= String(m).padStart(2,'0') %>"><%= String(m).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-ampm">
<option value="AM">AM</option>
<option value="PM">PM</option>
</select>
</div>
</td>

<td>
<select class="form-control break-select" name="has_break[]">
<option value="N">No</option>
<option value="Y">Yes</option>
</select>
</td>

<td>
<input type="hidden" name="break_start_time[]" class="time-value break-input">
<div class="time-12-picker break-time">
<select class="form-control time-hour">
<option value="">HH</option>
<% for(let h=1; h<=12; h++){ %>
<option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-minute">
<option value="">MM</option>
<% for(let m=0; m<60; m++){ %>
<option value="<%= String(m).padStart(2,'0') %>"><%= String(m).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-ampm">
<option value="AM">AM</option>
<option value="PM">PM</option>
</select>
</div>
</td>

<td>
<input type="hidden" name="break_end_time[]" class="time-value break-input">
<div class="time-12-picker break-time">
<select class="form-control time-hour">
<option value="">HH</option>
<% for(let h=1; h<=12; h++){ %>
<option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-minute">
<option value="">MM</option>
<% for(let m=0; m<60; m++){ %>
<option value="<%= String(m).padStart(2,'0') %>"><%= String(m).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-ampm">
<option value="AM">AM</option>
<option value="PM">PM</option>
</select>
</div>
</td>

<td>
<input type="hidden" name="out_time[]" class="time-value">
<div class="time-12-picker">
<select class="form-control time-hour">
<option value="">HH</option>
<% for(let h=1; h<=12; h++){ %>
<option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-minute">
<option value="">MM</option>
<% for(let m=0; m<60; m++){ %>
<option value="<%= String(m).padStart(2,'0') %>"><%= String(m).padStart(2,'0') %></option>
<% } %>
</select>
<select class="form-control time-ampm">
<option value="AM">AM</option>
<option value="PM">PM</option>
</select>
</div>
</td>

</tr>

<% }) %>

</tbody>

</table>
</div>
<div class="text-end mt-3">

<button type="submit" class="save-btn">
Save Attendance
</button>

</div>

</form>

</div>

</div>

<script>
function updateTimeValue(picker){
const hour = picker.querySelector('.time-hour').value;
const minute = picker.querySelector('.time-minute').value;
const ampm = picker.querySelector('.time-ampm').value;
const hidden = picker.previousElementSibling;

if(!hour || !minute){
hidden.value = '';
return;
}

let hour24 = Number(hour);

if(ampm == 'AM' && hour24 == 12){
hour24 = 0;
}

if(ampm == 'PM' && hour24 != 12){
hour24 += 12;
}

hidden.value = `${String(hour24).padStart(2,'0')}:${minute}`;
}

document.querySelectorAll('.time-12-picker').forEach(function(picker){
picker.querySelectorAll('select').forEach(function(select){
select.addEventListener('change', function(){
updateTimeValue(picker);
});
});
});

document.querySelectorAll('.break-select').forEach(function(select){
select.addEventListener('change', function(){
const row = this.closest('tr');
const fields = row.querySelectorAll('.break-time');

fields.forEach(function(field){
field.style.display = select.value == 'Y' ? 'block' : 'none';
if(select.value != 'Y'){
field.querySelectorAll('select').forEach(function(selectBox){
selectBox.value = selectBox.classList.contains('time-ampm') ? 'AM' : '';
});
}
});

row.querySelectorAll('.break-input').forEach(function(input){
if(select.value != 'Y'){
input.value = '';
}
});
});
});
</script>

<%- include('footer') %>
