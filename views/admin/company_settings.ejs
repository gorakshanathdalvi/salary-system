<%- include('navbar') %>

<style>

body{
background:#f1f5fb;
font-family:'Segoe UI',sans-serif;
}

.page-header{
background:linear-gradient(135deg,#007bff,#00c6ff);
color:white;
padding:20px 25px;
border-radius:10px;
margin-bottom:25px;
}

.form-card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
}

.section-title{
font-size:18px;
font-weight:600;
margin-bottom:20px;
border-left:4px solid #007bff;
padding-left:10px;
}

.form-control{
height:45px;
border-radius:8px;
}

.save-btn{
background:#007bff;
color:white;
border:none;
height:45px;
padding:0 35px;
border-radius:8px;
font-weight:600;
}

.save-btn:hover{
background:#0056d2;
}

</style>

<div class="container-fluid admin-page-container py-4">

<div class="page-header">
<h4 class="mb-0">Company Settings</h4>
</div>

<div class="form-card">
<% if(success_msg){ %>
<div class="alert alert-success auto-hide">
<%= success_msg %>
</div>
<% } %>

<% if(error_msg){ %>
<div class="alert alert-danger auto-hide">
<%= error_msg %>
</div>
<% } %>
<br>
<form action="/update_company_settings" method="POST">

<div class="section-title">Company Information</div>

<div class="row">

<div class="col-md-6 mb-3">
<label>Company Name</label>
<input type="text" class="form-control" name="company_name" value="<%= settings.company_name %>">
</div>

<div class="col-md-6 mb-3">
<label>Company Mobile</label>
<input type="text" class="form-control" name="company_mobile" value="<%= settings.company_mobile %>">
</div>

<div class="col-md-12 mb-3">
<label>Company Address</label>
<textarea class="form-control" name="company_address"><%= settings.company_address %></textarea>
</div>

</div>

<hr>

<div class="section-title">Duty Settings</div>

<div class="row">

<div class="col-md-3 mb-3">
<label>Total Shift Hours</label>
<input type="number" step="0.1" class="form-control" name="shift_hours" value="<%= settings.shift_hours %>">
</div>

<div class="col-md-3 mb-3">
<label>Duty Hours</label>
<input type="number" step="0.1" class="form-control" name="duty_hours" value="<%= settings.duty_hours %>">
</div>

<div class="col-md-3 mb-3">
<label>Lunch Break (minutes)</label>
<input type="number" class="form-control" name="lunch_break" value="<%= settings.lunch_break %>">
</div>

<div class="col-md-3 mb-3">
<label>Overtime Start After (hours)</label>
<input type="number" step="0.1" class="form-control" name="ot_start_after" value="<%= settings.ot_start_after %>">
</div>

</div>

<hr>

<div class="text-end">

<button type="submit" class="btn save-btn">
Update Settings
</button>

</div>

</form>

</div>

</div>
<script>

setTimeout(function(){

let alerts = document.querySelectorAll('.auto-hide');

alerts.forEach(function(alert){
alert.style.transition = "opacity 0.5s";
alert.style.opacity = "0";

setTimeout(()=>{
alert.remove();
},500);

});

},3000);

</script>

<%- include('footer') %>
