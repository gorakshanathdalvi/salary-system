<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Login</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    min-height:100vh;
    background:#f5f7fb;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Segoe UI', sans-serif;
    padding:20px;
}

/* Main Card */
.login-box{
    width:100%;
    max-width:950px;
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 20px 40px rgba(0,0,0,0.1);
}

/* Left Side */
.login-left{
    background:linear-gradient(135deg,#007bff,#00c6ff);
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    text-align:center;
    padding:40px;
}

.login-left h2{
    font-weight:700;
}

.login-left img{
    width:70%;
    max-width:220px;
    margin-top:20px;
}

/* Right Form */
.login-right{
    padding:60px 50px;
}

.login-right h3{
    font-weight:700;
    margin-bottom:10px;
}

.login-right p{
    color:#777;
    margin-bottom:30px;
}

.form-control{
    height:45px;
    border-radius:8px;
}

.login-btn{
    height:45px;
    border-radius:8px;
    background:#007bff;
    border:none;
    font-weight:600;
}

.login-btn:hover{
    background:#0056d2;
}

/* Tablet */
@media (max-width:992px){

.login-right{
padding:40px 30px;
}

.login-left img{
width:60%;
}

}

/* Mobile */
@media (max-width:768px){

.login-box{
border-radius:12px;
}

.login-left{
padding:30px 20px;
}

.login-left img{
width:120px;
}

.login-right{
padding:30px 25px;
}

}

/* Small Mobile */
@media (max-width:480px){

.login-right h3{
font-size:22px;
}

.login-left h2{
font-size:22px;
}

.login-right{
padding:25px 20px;
}

}

</style>
</head>

<body>

<div class="login-box row g-0">

<!-- Left -->
<div class="col-lg-6 col-md-6 col-12 login-left">

<div>
<h2>Payroll System</h2>
<p>Labour Contractor Management</p>

<img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" class="img-fluid">

</div>

</div>

<!-- Right -->
<div class="col-lg-6 col-md-6 col-12 login-right">

<h3>Admin Login</h3>
<p>Enter your credentials to access dashboard</p>

<% if (typeof error !== 'undefined') { %>
<div class="alert alert-danger"><%= error %></div>
<% } %>

<form action="/login/login" method="POST">

<div class="mb-3">
<label>Username</label>
<input type="text" class="form-control" name="username" required placeholder="Enter username">
</div>

<div class="mb-4">
<label>Password</label>
<input type="password" class="form-control" name="password" required placeholder="Enter password">
</div>

<button class="btn login-btn w-100">
Login
</button>

</form>

</div>

</div>

</body>
</html>